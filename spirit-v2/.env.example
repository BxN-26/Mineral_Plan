PORT=3000
JWT_SECRET=change_this_to_a_very_long_random_secret_for_access_tokens
JWT_REFRESH_SECRET=change_this_to_a_different_very_long_random_secret_for_refresh
DB_PATH=./db/spirit.db
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Comptes créés automatiquement à la première installation ─────────────────
# Superadmin (développeur) : compte technique secret, invisible pour les admins
# Ne jamais partager ces identifiants avec le client
SUPERADMIN_EMAIL=dev@spirit-app.internal
SUPERADMIN_PASSWORD=change_this_to_a_strong_secret_password

# Admin (opérateur du club) : reçoit must_change_password=1 à la première install
# L'admin devra définir son propre mot de passe lors de sa première connexion
ADMIN_EMAIL=admin@votreclub.fr
ADMIN_INITIAL_PASSWORD=change_this_temporary_password
