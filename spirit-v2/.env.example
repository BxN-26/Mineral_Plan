PORT=3000
JWT_SECRET=change_this_to_a_very_long_random_secret_for_access_tokens
DB_PATH=./db/spirit.db
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Comptes créés automatiquement à la première installation ─────────────────
SUPERADMIN_EMAIL=dev@spirit-app.internal
SUPERADMIN_PASSWORD=change_this_to_a_strong_secret_password
ADMIN_EMAIL=admin@votreclub.fr
ADMIN_INITIAL_PASSWORD=change_this_temporary_password

# ── Email — réinitialisation de mot de passe (optionnel) ─────────────────────
# Laisser vide pour désactiver le reset par email.
# Fournisseurs courants :
#   OVH         : SMTP_HOST=ssl0.ovh.net
#   Gandi       : SMTP_HOST=mail.gandi.net
#   Infomaniak  : SMTP_HOST=mail.infomaniak.com
#   Ionos/1&1   : SMTP_HOST=smtp.ionos.fr
#   Gmail       : SMTP_HOST=smtp.gmail.com  (nécessite un mot de passe d'application)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Minéral Plan <noreply@votreclub.fr>

# ── Push Web (optionnel, PWA) ─────────────────────────────────────────────────
# Laisser vide pour désactiver les notifications push. Générer les clés avec :
#   node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@votreclub.fr
